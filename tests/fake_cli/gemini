#!/bin/sh

drain_stdin() {
  if [ ! -t 0 ]; then
    cat >/dev/null
  fi
}

run_scenario() {
  case "${LOOP_FAKE_SCENARIO:-pass}" in
    pass)
      cat <<'EOF'
# Implementation Summary - Loop 1

## Result
PASS
EOF
      ;;
    fail)
      cat <<'EOF'
# Implementation Summary - Loop 1

## Result
FAIL
EOF
      ;;
    malformed)
      echo "malformed fake gemini output"
      ;;
    rate_limit)
      echo "rate limit exceeded: fake gemini quota reached" >&2
      exit 42
      ;;
    *)
      echo "unknown LOOP_FAKE_SCENARIO: ${LOOP_FAKE_SCENARIO}" >&2
      exit 2
      ;;
  esac
}

case "${1:-}" in
  --version|-v)
    echo "fake-gemini 1.0.0"
    exit 0
    ;;
  --self-test)
    LOOP_FAKE_SCENARIO=pass "$0" </dev/null >/dev/null || exit 1
    LOOP_FAKE_SCENARIO=fail "$0" </dev/null >/dev/null || exit 1
    LOOP_FAKE_SCENARIO=malformed "$0" </dev/null >/dev/null || exit 1
    if LOOP_FAKE_SCENARIO=rate_limit "$0" </dev/null >/dev/null 2>/dev/null; then
      exit 1
    fi
    "$0" --version >/dev/null || exit 1
    "$0" -v >/dev/null || exit 1
    echo "fake gemini self-test ok"
    exit 0
    ;;
esac

drain_stdin
run_scenario
